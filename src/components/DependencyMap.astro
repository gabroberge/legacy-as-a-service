---
---

<div
  class="dep-map-root overflow-hidden rounded-[10px] border border-white/12 bg-panel shadow-[0_0_0_1px_rgba(0,0,0,0.4),0_24px_64px_rgba(0,0,0,0.45)]"
  data-dep-map
>
  <div class="flex flex-col gap-2 border-b border-white/7 bg-inset px-3 py-2.5 sm:flex-row sm:items-center sm:justify-between sm:gap-2 sm:px-3.5 font-mono text-xs text-muted">
    <div class="flex min-w-0 items-center gap-2">
      <div class="flex shrink-0 gap-1">
        <span class="size-2 rounded-full bg-danger/70"></span>
        <span class="size-2 rounded-full bg-amber/70"></span>
        <span class="size-2 rounded-full bg-terminal/50"></span>
      </div>
      <span class="truncate">legacy-dependency-map.graph</span>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <span class="dep-map-hint hidden text-xs text-dim md:inline">drag nodes to inspect dependency ownership</span>
      <button
        type="button"
        class="dep-map-reset rounded border border-white/12 px-2 py-1 text-xs text-dim transition hover:border-amber hover:text-amber"
      >
        reset
      </button>
      <span class="tag tag--live"><span class="tag-dot"></span> live</span>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-1.5 border-b border-white/7 bg-inset p-2.5 sm:flex sm:flex-wrap sm:gap-1.5 sm:px-3.5">
    <button type="button" class="dep-map-autolayout rounded border border-white/12 px-2 py-1.5 font-mono text-xs text-dim transition hover:border-amber hover:text-amber sm:py-0.5">
      Auto-layout
    </button>
    <button type="button" class="dep-map-simplify rounded border border-white/12 px-2 py-1.5 font-mono text-xs text-dim transition hover:border-amber hover:text-amber sm:py-0.5">
      Simplify
    </button>
    <button type="button" class="dep-map-migrate col-span-2 rounded border border-danger/35 bg-danger/10 px-2 py-1.5 font-mono text-xs text-danger transition hover:border-danger hover:bg-danger/20 sm:col-span-1 sm:py-0.5">
      Run migration
    </button>
  </div>

  <div class="dep-map-canvas relative min-h-[280px] select-none p-3 sm:min-h-[340px] sm:p-4">
    <div
      class="dep-drag-badge pointer-events-none absolute z-20 hidden rounded border border-danger/40 bg-danger/15 px-2 py-0.5 font-mono text-[0.6rem] font-semibold tracking-wider text-danger uppercase"
      data-drag-badge
    >
      do not touch
    </div>
    <div
      class="dep-toast pointer-events-none absolute top-3 left-1/2 z-20 hidden -translate-x-1/2 rounded border border-amber/40 bg-bg/95 px-3 py-1.5 font-mono text-[0.65rem] text-amber shadow-lg"
      data-toast
    ></div>
    <svg class="dep-map-svg block h-auto w-full touch-none" viewBox="0 0 480 300" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <marker id="dep-arrow" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
          <path d="M0,0 L6,3 L0,6" fill="#f05252" />
        </marker>
      </defs>
      <g class="dep-edges" data-dep-edges></g>
      <g class="dep-nodes" data-dep-nodes></g>
      <g class="dep-blocked-label" data-dep-blocked></g>
    </svg>
  </div>

  <div class="dep-map-log flex max-h-24 flex-col gap-0.5 overflow-y-auto border-t border-white/7 bg-inset px-3.5 py-2 font-mono text-xs leading-snug text-dim" data-dep-log></div>
</div>

<script>
  import { initDependencyMaps } from "../scripts/dependency-map";

  initDependencyMaps();
  document.addEventListener("astro:page-load", initDependencyMaps);
</script>
