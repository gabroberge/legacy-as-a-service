---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Legacy-as-a-Service",
  description = "Scale your technical debt with confidence. Preserve, scale, and monetize your legacy systems.",
} = Astro.props;

const navLinks = [
  { href: "#problem", label: "Problem" },
  { href: "#features", label: "Modules" },
  { href: "#metrics", label: "Telemetry" },
  { href: "#pricing", label: "Pricing" },
  { href: "#faq", label: "FAQ" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="fixed inset-x-0 top-0 z-50 border-b border-white/7 bg-bg/95 backdrop-blur-sm">
      <nav class="flex items-center justify-between gap-3 px-4 py-3 sm:px-6">
        <a href="#" class="flex min-w-0 items-center gap-2 text-sm font-semibold tracking-tight sm:gap-2.5 sm:text-[0.95rem]">
          <span class="grid size-7 shrink-0 place-items-center border border-amber bg-amber/15 font-mono text-[0.7rem] font-bold text-amber">L</span>
          <span class="truncate sm:hidden">LaaS</span>
          <span class="hidden truncate sm:inline">Legacy-as-a-Service</span>
          <span class="hidden rounded border border-white/7 px-1.5 py-0.5 font-mono text-[0.6rem] text-dim sm:inline">v2.4.1</span>
        </a>
        <ul class="hidden items-center gap-5 lg:flex">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-[0.8125rem] text-muted transition hover:text-[#e8eaef]">{link.label}</a>
            </li>
          ))}
        </ul>
        <div class="flex shrink-0 items-center gap-2">
          <a href="/app" class="hidden rounded-md border border-white/12 px-3 py-1.5 font-mono text-[0.7rem] text-muted transition hover:border-amber hover:text-amber sm:inline-flex">
            Control Plane
          </a>
          <a href="#cta" class="rounded-md bg-amber px-3 py-2 font-mono text-[0.7rem] font-semibold text-bg transition hover:brightness-110 sm:px-3.5 sm:py-1.5">
            <span class="sm:hidden">Defer</span>
            <span class="hidden sm:inline">Defer Migration</span>
          </a>
        </div>
      </nav>
      <div class="border-t border-white/7 lg:hidden">
        <ul class="flex gap-1 overflow-x-auto px-4 py-2 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
          {navLinks.map((link) => (
            <li class="shrink-0">
              <a
                href={link.href}
                class="block rounded-md border border-white/7 px-3 py-1.5 font-mono text-[0.7rem] text-muted transition hover:border-amber/40 hover:text-amber"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </header>

    <slot />

    <footer class="border-t border-white/7 py-8">
      <div class="container-page flex flex-col gap-4 text-[0.8125rem] text-dim sm:flex-row sm:items-center sm:justify-between">
        <span>© {new Date().getFullYear()} Legacy-as-a-Service — unchanged since 2019</span>
        <ul class="flex flex-wrap gap-x-5 gap-y-2">
          <li><a href="/app" class="text-muted transition hover:text-[#e8eaef]">Control Plane</a></li>
          <li><a href="#" class="text-muted transition hover:text-[#e8eaef]">Status: Migration Blocked</a></li>
          <li><a href="#" class="text-muted transition hover:text-[#e8eaef]">Docs (deprecated)</a></li>
          <li><a href="#" class="text-muted transition hover:text-[#e8eaef]">Owner: unknown</a></li>
        </ul>
      </div>
    </footer>
  </body>
</html>
