---
import "../styles/global.css";
import { sitePath } from "../lib/site-url";

interface Props {
  title?: string;
}

const { title = "Control Plane — Legacy-as-a-Service" } = Astro.props;

const tabs = [
  { id: "overview", label: "Overview" },
  { id: "deps", label: "Dependency Map" },
  { id: "refactors", label: "Refactor Queue" },
  { id: "conventions", label: "Conventions" },
  { id: "reviews", label: "AI Review Noise" },
  { id: "incidents", label: "Incident Log" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={sitePath("/favicon.svg")} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <header class="sticky top-0 z-50 border-b border-white/7 bg-bg/95 backdrop-blur-sm">
      <div class="mx-auto flex max-w-7xl items-center justify-between gap-3 px-4 py-3 sm:px-6">
        <a href={sitePath("/app")} class="flex min-w-0 items-center gap-2 font-semibold">
          <span class="grid size-7 shrink-0 place-items-center border border-amber bg-amber/15 font-mono text-[0.7rem] font-bold text-amber">L</span>
          <span class="truncate text-sm sm:text-base">LaaS Control Plane</span>
          <span class="tag tag--live hidden sm:inline-flex"><span class="tag-dot"></span> live</span>
        </a>
        <div class="flex items-center gap-2">
          <span class="hidden font-mono text-xs text-dim sm:inline">v2.4.1 · local-first</span>
          <a href={sitePath("/")} class="btn btn-secondary px-3 py-2 text-xs!">← Marketing</a>
        </div>
      </div>
    </header>

    <slot />

    <footer class="border-t border-white/7 py-4 text-center font-mono text-xs text-dim">
      All data stored in localStorage · owner: unknown · migration: blocked
    </footer>
  </body>
</html>
